{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "crons": [
    { "path": "/api/keepalive", "schedule": "0 0 * * *" }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.py" },
    { "source": "/agent/:path*", "destination": "/api/index.py" },
    { "source": "/run", "destination": "/api/index.py" },
    { "source": "/health", "destination": "/api/index.py" },
    { "source": "/config", "destination": "/api/index.py" },
    { "source": "/suggestions", "destination": "/api/index.py" },
    { "source": "/trace/:path*", "destination": "/api/index.py" },
    { "source": "/keepalive", "destination": "/api/index.py" },
    {
      "source": "/:path((?!assets/|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
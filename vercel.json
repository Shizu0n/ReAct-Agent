{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.py"
    },
    {
      "source": "/agent/:path*",
      "destination": "/api/index.py"
    },
    {
      "source": "/run",
      "destination": "/api/index.py"
    },
    {
      "source": "/health",
      "destination": "/api/index.py"
    },
    {
      "source": "/config",
      "destination": "/api/index.py"
    },
    {
      "source": "/trace/:path*",
      "destination": "/api/index.py"
    },
    {
      "source": "/:path((?!assets/|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}

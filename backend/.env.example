# Free/freemium model providers. Fill only the ones you want to use.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

GITHUB_MODELS_TOKEN=
GITHUB_MODELS_MODEL=

OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_SITE_URL=http://localhost
OPENROUTER_APP_NAME=01-react-agent

CF_ACCOUNT_ID=
CF_WORKERS_AI_TOKEN=
CF_WORKERS_AI_MODEL=@cf/meta/llama-3-8b-instruct

# Optional web search. Leave blank to avoid Tavily API calls.
TAVILY_API_KEY=
TAVILY_MAX_RESULTS=2
TAVILY_SNIPPET_CHARS=360
